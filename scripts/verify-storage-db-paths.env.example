# DB + Storage (우리 프로젝트 = 파일이 들어간 쪽)
# Postgres URI는 Dashboard → Connect → "Pooling mode" 연결 문자열 권장
DATABASE_URL=

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 또는 마이그레이션용 파일만 있다면 DEST_* 로도 인식합니다 (.env.storage-migrate 자동 로드)
# DEST_SUPABASE_URL=
# DEST_SUPABASE_SERVICE_ROLE_KEY=

# 한 파일만 쓰려면:
# VERIFY_DOTENV_PATH=C:\Projects\dashboard-data\chart-api\.env.local

# 테이블별 샘플 행 수 (기본 12)
# VERIFY_SAMPLE_LIMIT=12

# parse_runs.raw_payload 에 storageBucket 없을 때 쓸 기본 PDF 버킷
# VERIFY_PDF_BUCKET=pdf-uploads

# report_case_images.storage_path 조회 시 버킷
# VERIFY_CASE_IMAGE_BUCKET=case-image
