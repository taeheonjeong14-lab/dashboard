# Copy this to .env.storage-migrate (repo root) and fill in. Do not commit secrets.

# Source Supabase project (service role — full storage read)
SOURCE_SUPABASE_URL=https://xxxx.supabase.co
SOURCE_SUPABASE_SERVICE_ROLE_KEY=
SOURCE_BUCKET=pdf-uploads

# Destination Supabase project (service role — storage write)
DEST_SUPABASE_URL=https://yyyy.supabase.co
DEST_SUPABASE_SERVICE_ROLE_KEY=
DEST_BUCKET=pdf-uploads

# Multiple buckets in one run (same name on source & dest):
# MIGRATE_BUCKETS=pdf-uploads,case-image,hospital-assets
# Or different names per side:
# MIGRATE_BUCKET_PAIRS=pdf-uploads:pdf-uploads,legacy-case:case-image
# When either is set, SOURCE_BUCKET / DEST_BUCKET are ignored.
# Checkpoints: scripts/storage-migrate/checkpoint-<bucket>.json (folder override):
# CHECKPOINT_DIR=scripts/storage-migrate

# Optional path rewrite: destKey = MIGRATE_ADD_PREFIX + (srcKey without MIGRATE_STRIP_PREFIX prefix)
# Example: strip old root and write under extract-uploads/
MIGRATE_STRIP_PREFIX=
MIGRATE_ADD_PREFIX=

# Only migrate objects whose path equals or starts with this prefix (no leading slash required)
MIGRATE_FILTER_PREFIX=

# Parallel uploads (default 4)
CONCURRENCY=4

# Resume file — safe to delete to restart from scratch (or use --clear-checkpoint)
# CHECKPOINT_FILE=scripts/storage-migrate/checkpoint.json

# Optional: load a specific dotenv file
# DOTENV_PATH=C:\secrets\.env.storage-migrate
