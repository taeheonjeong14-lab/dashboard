{
  "_note": "이 파일을 decode-supabase-batch.config.json 로 복사한 뒤 jobs 목록을 채우세요. 리포 루트에서: node scripts/sql/decode-supabase-batch.mjs",
  "jobs": [
    {
      "input": "scripts/sql/tmp/paste-generated-run-content.json",
      "output": "scripts/sql/tmp/generated-run-content-inserts.sql",
      "table": "generated_run_content"
    },
    {
      "input": "scripts/sql/tmp/paste-attach-export-for-decoder.json",
