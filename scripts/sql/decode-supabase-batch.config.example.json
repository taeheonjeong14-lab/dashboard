      "table": "health_review_share_links"
    },
    {
      "input": "scripts/sql/tmp/paste-documents-export-for-decoder.json",
      "output": "scripts/sql/tmp/documents-inserts.sql",
      "table": "documents"
    },
    {
      "input": "scripts/sql/tmp/paste-parse-runs-export-for-decoder.json",
      "output": "scripts/sql/tmp/parse-runs-inserts.sql",
      "table": "parse_runs"
    },
    {
      "input": "scripts/sql/tmp/paste-report-case-images-export-for-decoder.json",
      "output": "scripts/sql/tmp/report-case-images-inserts.sql",
      "table": "report_case_images"
    },
    {
      "input": "scripts/sql/tmp/paste-result-basic-info-export-for-decoder.json",
      "output": "scripts/sql/tmp/result-basic-info-inserts.sql",
      "table": "result_basic_info"
    },
    {
      "input": "scripts/sql/tmp/paste-result-chart-by-date-export-for-decoder.json",
      "output": "scripts/sql/tmp/result-chart-by-date-inserts.sql",
