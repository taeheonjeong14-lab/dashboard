# Supabase (dashboard-ui와 동일 프로젝트면 anon 또는 서버 전용으로 분리)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 필요 시 서버에서만 (키워드 타겟 CRUD·관리용 등). 브라우저에 넣지 말 것.
# SUPABASE_SERVICE_ROLE_KEY=

# 공개 기준 URL (이메일·리다이렉트 등 쓸 때)
NEXT_PUBLIC_APP_URL=

# 브라우저 CORS 허용 오리진 (쉼표 구분). 비우면 lib/cors.ts 기본값(vet-solution·dashboard-ui 등).
# DASHBOARD_API_ALLOWED_ORIGINS=https://example.com
